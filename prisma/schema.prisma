// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

enum BattleStatus {
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
  ABANDONED
}

enum BattleResult {
  PENDING
  WIN
  LOSS
  CANCEL
  DRAW
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BATTLE_JOIN
  BATTLE_WIN
  REFUND
  REFERRAL_COMMISSION
  ADMIN_CREDIT
  ADMIN_DEBIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
  FAILED
}

enum WithdrawalMethod {
  UPI
  BANK
}

enum NotificationType {
  WELCOME
  REFERRAL
  PROFILE_UPDATE
  BATTLE_RESULT
  BATTLE_CANCELLED
  DISPUTE_RAISED
  DISPUTE_RESOLVED
  DEPOSIT_SUCCESS
  WITHDRAWAL_SUBMITTED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  ADMIN_ALERT
  SYSTEM
}

model User {
  id                    String    @id @default(cuid())
  phone                 String    @unique
  name                  String    @default("Player")
  avatar                String?
  userType              String    @default("Player") // Player, Admin
  password              String?
  referralCode          String    @unique
  referredById          String?
  referredBy            User?     @relation("Referral", fields: [referredById], references: [id])
  referrals             User[]    @relation("Referral")
  
  kyc                   KYC?
  
  // Financial Fields
  walletBalance         Decimal   @default(0)
  totalDeposited        Decimal   @default(0)
  totalWithdrawn        Decimal   @default(0)
  totalWinnings         Decimal   @default(0)
  totalReferralEarnings Decimal   @default(0)
  
  status                String    @default("Active") // Active, Inactive, Suspended, Banned
  accountDeleted        Boolean   @default(false)
  deletedAt             DateTime?
  lastLoginAt           DateTime?
  deviceInfo            String?
  
  otp                   String?
  otpExpiry             DateTime?

  // Payment Details
  upiId                 String?
  bankAccountNumber     String?
  bankIfscCode          String?
  bankAccountHolderName String?
  preferredWithdrawalMethod WithdrawalMethod @default(UPI)
  
  // Relations for Battles
  createdBattles        Battle[]  @relation("CreatedBattles")
  joinedBattles         Battle[]  @relation("JoinedBattles")
  wonBattles            Battle[]  @relation("WonBattles")
  proofSubmitted        Battle[]  @relation("ProofSubmittedBy")
  decidedBattles        Battle[]  @relation("DecidedBy")
  
  // Relations for Transactions
  walletTransactions    WalletTransaction[]
  referralEarnings      ReferralEarning[] @relation("Referrer")
  refereeEarnings       ReferralEarning[] @relation("Referee")
  
  // Relations for Withdrawals
  withdrawals           WithdrawalRequest[] @relation("UserWithdrawals")
  processedWithdrawals  WithdrawalRequest[] @relation("ProcessedWithdrawals")

  // Notifications
  notifications         Notification[]

  // Audit
  administeredTransactions WalletTransaction[] @relation("AdminTransactions")
  kycReviewed           KYC[]     @relation("KYCReviewedBy")

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([phone])
  @@index([referralCode])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  metadata  String?          // JSON string for SQLite compatibility
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model Battle {
  id                 String       @id @default(cuid())
  battleId           String       @unique
  creatorId          String
  creator            User         @relation("CreatedBattles", fields: [creatorId], references: [id])
  opponentId         String?
  opponent           User?        @relation("JoinedBattles", fields: [opponentId], references: [id])
  entryFee           Decimal
  prizeAmount        Decimal
  platformFee        Decimal
  roomCode           String
  status             BattleStatus @default(OPEN)
  result             BattleResult @default(PENDING)
  winnerId           String?
  winner             User?        @relation("WonBattles", fields: [winnerId], references: [id])
  resultPostedById   String?
  resultSubmittedAt  DateTime?
  screenshotUrl      String?
  videoProofUrl      String?
  proofSubmittedById String?
  proofSubmittedBy   User?        @relation("ProofSubmittedBy", fields: [proofSubmittedById], references: [id])
  disputed           Boolean      @default(false)
  disputeReason      String?
  adminDecision      String?
  adminNotes         String?
  decidedById        String?
  decidedBy          User?        @relation("DecidedBy", fields: [decidedById], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  walletTransactions WalletTransaction[]
  referralEarnings   ReferralEarning[]
}

model WalletTransaction {
  id            String            @id @default(cuid())
  transactionId String            @unique
  userId        String
  user          User              @relation(fields: [userId], references: [id])
  amount        Decimal
  type          TransactionType
  status        TransactionStatus @default(SUCCESS)
  
  battleId      String?
  battle        Battle?           @relation(fields: [battleId], references: [id])
  
  withdrawalId  String?
  withdrawal    WithdrawalRequest? @relation(fields: [withdrawalId], references: [id])
  
  description   String
  metadata      String?           // JSON stringified metadata
  
  adminId       String?
  admin         User?             @relation("AdminTransactions", fields: [adminId], references: [id])
  
  createdAt     DateTime          @default(now())

  @@index([userId])
  @@index([transactionId])
  @@index([type])
  @@index([status])
}

model ReferralEarning {
  id            String    @id @default(cuid())
  referrerId    String
  referrer      User      @relation("Referrer", fields: [referrerId], references: [id])
  refereeId     String
  referee       User      @relation("Referee", fields: [refereeId], references: [id])
  battleId      String
  battle        Battle    @relation(fields: [battleId], references: [id])
  amount        Decimal
  percentage    Decimal
  createdAt     DateTime  @default(now())

  @@index([referrerId])
  @@index([refereeId])
}

model SystemSettings {
  id                String   @id @default("global")

  // General
  platformName      String   @default("Bajiger Ludo")
  tagline           String   @default("Play. Compete. Earn.")
  logoUrl           String?
  contactEmail      String   @default("support@bajigerludo.com")
  supportWhatsApp   String   @default("+919999999999")
  maintenanceMode   Boolean  @default(false)

  // Referral Program
  referralEnabled   Boolean  @default(true)
  referralPercent   Decimal  @default(3.0)
  minEntryFee       Decimal  @default(0.0)

  // Wallet & Withdrawal
  minWithdrawalAmount    Decimal @default(100.0)
  dailyWithdrawalLimit   Decimal @default(10000.0)
  withdrawalFeePercent   Decimal @default(0.0)
  withdrawalFeeFixed     Decimal @default(0.0)
  autoApprovalLimit      Decimal @default(0.0)

  // Battle & Game Settings
  platformFeePercent       Decimal @default(10.0)
  minBattleEntry           Decimal @default(10.0)
  maxBattleEntry           Decimal @default(10000.0)
  autoCancelMinutes        Int     @default(15)
  resultSubmitWindowMinutes Int    @default(30)

  // Payment Gateway
  razorpayKeyId      String?
  razorpayKeySecret  String?
  cashfreeAppId      String?
  cashfreeSecretKey  String?
  zapupiKey          String?
  activePaymentGateway String   @default("NONE") // NONE, RAZORPAY, CASHFREE, ZAPUPI
  paymentTestMode    Boolean @default(true)
  webhookUrl         String  @default("http://localhost:3000/api/webhooks/payment")

  // Security
  otpExpiryMinutes      Int  @default(5)
  rateLimitPerMinute    Int  @default(10)
  sessionTimeoutMinutes Int  @default(60)
  kycRequired           Boolean @default(false)

  updatedAt         DateTime @updatedAt
}

model WithdrawalRequest {
  id                String           @id @default(cuid())
  withdrawalId      String           @unique
  userId            String
  user              User             @relation("UserWithdrawals", fields: [userId], references: [id])
  amount            Decimal
  status            WithdrawalStatus @default(PENDING)
  preferredMethod   WithdrawalMethod
  upiId             String?
  bankDetails       String?          // JSON stringified: { accountNumber, ifscCode, accountHolderName }
  notes             String?
  requestedAt       DateTime         @default(now())
  processedAt       DateTime?
  processedById     String?
  processedBy       User?            @relation("ProcessedWithdrawals", fields: [processedById], references: [id])
  rejectionReason   String?

  walletTransactions WalletTransaction[]

  @@index([userId])
  @@index([status])
}

enum KYCStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model KYC {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id])
  kycStatus           KYCStatus @default(PENDING)
  aadhaarFrontUrl     String?
  aadhaarBackUrl      String?
  panUrl              String?
  bankAccountNumber   String?
  bankIfscCode        String?
  bankHolderName      String?
  rejectionReason     String?
  submittedAt         DateTime?
  verifiedAt          DateTime?
  reviewedById        String?
  reviewedBy          User?     @relation("KYCReviewedBy", fields: [reviewedById], references: [id])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId])
  @@index([kycStatus])
}
